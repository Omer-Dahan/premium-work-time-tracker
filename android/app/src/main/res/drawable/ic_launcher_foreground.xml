<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clock ring (center 54,54, radius 28) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.5"
        android:pathData="M26,54 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0" />

    <!-- 12 o'clock tick -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M54,29 L54,35" />

    <!-- 3 o'clock tick -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M79,54 L73,54" />

    <!-- 6 o'clock tick -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M54,79 L54,73" />

    <!-- 9 o'clock tick -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M29,54 L35,54" />

    <!-- Hour hand at 10 o'clock (300 deg from 12): tip at (54 + 15*sin300, 54 - 15*cos300) = (41, 46.5) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M54,54 L41,46.5" />

    <!-- Minute hand at 10 min (60 deg from 12): tip at (54 + 21*sin60, 54 - 21*cos60) = (72.2, 43.5) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M54,54 L72.2,43.5" />

    <!-- Center dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M51,54 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />

</vector>
